{
  "name": "climier",
  "version": "1.0.0",
  "description": "JSON-first task DAG CLI for coordinating work, decisions, and claims",
  "keywords": [
    "dag",
    "tasks",
    "workflow",
    "coordination",
    "claims",
    "multi-session",
    "multi-agent",
    "cli"
  ],
  "type": "module",
  "bin": {
    "climier": "./bin/climier.mjs"
  },
  "main": "bin/climier.mjs",
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "test:watch": "node --test --watch test/",
    "test:concurrent": "node --test test/concurrent-claims.test.mjs test/orchestrator-flow.test.mjs",
    "pack:check": "npm pack --dry-run --json > /dev/null"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
